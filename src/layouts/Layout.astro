---
import { ClientRouter } from "astro:transitions";
import BaseHead from "@/components/BaseHead.astro";
import MainNav from "@/components/MainNav.astro";
import OrbContainer from "@/components/OrbContainer.astro";
import OrbControls from "@/components/OrbControls.astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import "@fontsource/cutive-mono";
import "@fontsource/lato/300.css";
import "@fontsource/lato/400.css";
import "@fontsource/lato/700.css";

type Props = {
  title: string;
  description: string;
  frontmatter?: {
    title: string;
    description: string;
  };
};

const { frontmatter } = Astro.props;
const title = frontmatter?.title || Astro.props.title;
const description = frontmatter?.description || Astro.props.description;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <ClientRouter />
  </head>
  <body class="max-h-screen max-w-screen overflow-hidden">
    <SpeedInsights />
    <OrbContainer />
    <MainNav />
    <slot />
    <OrbControls transition:persist />
    <script>
      // Vercel Analytics custom events via delegation: any element with a
      // `data-va-event` attribute fires that event on click, with any extra
      // `data-va-*` attributes passed as (non-personal) event properties.
      // No-op when the analytics script isn't present (e.g. local dev).
      const w = window as unknown as { __vaEventsBound?: boolean };
      if (!w.__vaEventsBound) {
        w.__vaEventsBound = true;
        document.addEventListener("click", (e) => {
          const el = (e.target as HTMLElement)?.closest?.("[data-va-event]");
          if (!(el instanceof HTMLElement)) return;
          const props: Record<string, string> = {};
          for (const attr of Array.from(el.attributes)) {
            if (attr.name.startsWith("data-va-") && attr.name !== "data-va-event") {
              props[attr.name.slice("data-va-".length)] = attr.value;
            }
          }
          (window as any).va?.("event", { name: el.dataset.vaEvent, ...props });
        });
      }
    </script>
  </body>
</html>
