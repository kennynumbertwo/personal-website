---
import Layout from "../layouts/Layout.astro";
import BracketHeader from "@/components/BracketHeader.astro";
import "../styles/page-fonts.css";
---

<Layout
  title="Kenny Tye - Contact"
  description="Contact information for Kenny Tye"
>
  <main
    class="flex flex-col h-full relative overflow-y-scroll px-4 pt-20 md:pt-25"
    x-reveal
  >
    <div class="mx-auto w-full max-w-[784px]">
      <BracketHeader text="Contact" />
      <div class="rte">
        <p class="animate">
          I'm currently available for select freelance work.
        </p>
        <p class="pb-10 animate">
          If you'd like to connect, please get in touch.
        </p>
      </div>
      <a
        href="mailto:kenny@destroybox.studio"
        target="_blank"
        class="z-10 hover:underline opacity-0 block animate"
        data-va-event="contact_click"
        data-va-source="contact"
        >kenny@destroybox.studio</a
      >
    </div>
  </main>
</Layout>
